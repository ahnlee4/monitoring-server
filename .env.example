COMPOSE_PROJECT_NAME=monitoring-server

POSTGRES_DB=monitoring
POSTGRES_USER=monitor
POSTGRES_PASSWORD=monitor123
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://monitor:monitor123@db:5432/monitoring

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost,http://127.0.0.1
COLLECTOR_TOKEN=change-me

FRONTEND_PORT=4173
VITE_API_BASE=/api
VITE_WS_PATH=/ws/dashboard

NGINX_PORT=80

COLLECTOR_DRIVER=rs485
COLLECTOR_INTERVAL_SECONDS=3
COLLECTOR_DEVICE_CODES=PRESS-01,FURNACE-01,PUMP-01
COLLECTOR_API_URL=http://backend:8000/api/ingest/telemetry
COLLECTOR_YUJIN_API_URL=http://backend:8000/api/yujin/ingest-map

RS485_SERIAL_PORT=/dev/ttyUSB0
RS485_BAUDRATE=9600
RS485_COMP_QTY=8
RS485_RESPONSE_TIMEOUT_SECONDS=0.8
RS485_INTER_REQUEST_DELAY_SECONDS=0.05
RS485_DEBUG_HEX=true
