COMPOSE_PROJECT_NAME=monitoring-server

POSTGRES_DB=monitoring
POSTGRES_USER=monitor
POSTGRES_PASSWORD=monitor123
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://monitor:monitor123@db:5432/monitoring

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost,http://127.0.0.1
COLLECTOR_TOKEN=change-me

FRONTEND_PORT=4173
VITE_API_BASE=/api
VITE_WS_PATH=/ws/dashboard

NGINX_PORT=8080

COLLECTOR_DRIVER=mock
COLLECTOR_INTERVAL_SECONDS=3
COLLECTOR_DEVICE_CODES=PRESS-01,FURNACE-01,PUMP-01
